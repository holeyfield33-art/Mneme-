# Required in Render and local development
DATABASE_URL=******HOST:5432/DB_NAME
OPENAI_API_KEY=sk-your-openai-key
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=noreply@example.com
RELAY_SECRET=replace-with-a-long-random-secret

# Optional flags
PERSONAL_MODE=false
PERSONAL_API_KEY=
HELIOS_ENABLED=true
LOCAL_EMBEDDINGS_FALLBACK=false

# Render provides PORT automatically.
# For local development, keep using: uvicorn main:app --host 0.0.0.0 --port 8000
