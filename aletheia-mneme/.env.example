# ──────────────────────────────────────────────────────────────────────────────
# Aletheia Mneme — Environment Variables
# Copy this file to `.env` and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Aletheia Mneme
APP_VERSION=0.1.0
DEBUG=false
# IMPORTANT: change to a long random string in production
SECRET_KEY=change-me-in-production

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://mneme:mneme@localhost:5432/mneme

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant (vector / semantic search) ─────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=mneme_memories

# ── OpenAI (embeddings) ────────────────────────────────────────────────────────
# Required for semantic search endpoints
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Stripe (billing) ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# ── Multi-agent relay ──────────────────────────────────────────────────────────
RELAY_TOKEN_EXPIRY_SECONDS=3600
MAX_MEMORIES_PER_AGENT=10000
